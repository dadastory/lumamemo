# ============================================================
# LumaMemo environment template
# Copy this file to `.env` and adjust values before deployment.
# ============================================================

# ------------------------------------------------------------
# 1. Initial administrator
# ------------------------------------------------------------
LUMAMEMO_ADMIN_EMAIL=
LUMAMEMO_ADMIN_NAME=LumaMemo
LUMAMEMO_ADMIN_PASSWORD=LM1234@!

# ------------------------------------------------------------
# 2. Application runtime
# ------------------------------------------------------------
# Required: 32+ character random secret for encrypted sessions.
NUXT_SESSION_PASSWORD=

# Color mode: light, dark, or system.
NUXT_PUBLIC_COLOR_MODE_PREFERENCE=light

# Published application image. For local source builds, see docker-compose.local-build.yml.
LUMAMEMO_IMAGE=dadastory/lumamemo:latest

# Public gateway exposed on the host.
GATEWAY_IMAGE=nginx:alpine
GATEWAY_PORT=3000

# Development-only: allow insecure cookies on non-HTTPS origins.
NUXT_ALLOW_INSECURE_COOKIE=false

# ------------------------------------------------------------
# 3. Database
# ------------------------------------------------------------
DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://lumamemo:lumamemo-postgres-password@postgres:5432/lumamemo

# PostgreSQL sidecar used by third-party/middleware/docker-compose.yml.
POSTGRES_IMAGE=postgres:17
POSTGRES_DB=lumamemo
POSTGRES_USER=lumamemo
POSTGRES_PASSWORD=lumamemo-postgres-password

# ------------------------------------------------------------
# 4. Authentication
# ------------------------------------------------------------
NUXT_PUBLIC_OAUTH_GITHUB_ENABLED=false
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

NUXT_PUBLIC_OAUTH_OIDC_ENABLED=false
NUXT_PUBLIC_OAUTH_OIDC_LABEL=OIDC
NUXT_OAUTH_OIDC_ISSUER=
NUXT_OAUTH_OIDC_CLIENT_ID=
NUXT_OAUTH_OIDC_CLIENT_SECRET=
NUXT_OAUTH_OIDC_SCOPE=openid email profile
NUXT_OAUTH_OIDC_CLIENT_AUTH_METHOD=client_secret_post

# ------------------------------------------------------------
# 5. Maps and reverse geocoding
# ------------------------------------------------------------
# Map provider: maplibre or mapbox.
NUXT_PUBLIC_MAP_PROVIDER=maplibre

# Built-in local MapLibre style served by the gateway.
NUXT_PUBLIC_MAP_MAPLIBRE_STYLE=/maps/style.json?v=global
NUXT_PUBLIC_MAP_MAPLIBRE_TOKEN=

# Optional Mapbox configuration.
NUXT_PUBLIC_MAP_MAPBOX_STYLE=mapbox://styles/mapbox/standard
NUXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NUXT_MAPBOX_ACCESS_TOKEN=

# Optional Nominatim reverse geocoding base URL.
NUXT_NOMINATIM_BASE_URL=

# Local map and geocoding sidecars.
PMTILES_IMAGE=protomaps/go-pmtiles:latest
PMTILES_TILESET=global
PMTILES_FILENAME=global.pmtiles
MAPLIBRE_IMAGE=nginx:alpine

NOMINATIM_IMAGE=mediagis/nominatim:5.3.2
NOMINATIM_PBF_URL=https://download.geofabrik.de/asia/china-latest.osm.pbf
NOMINATIM_REPLICATION_URL=
NOMINATIM_PASSWORD=lumamemo-nominatim-password
NOMINATIM_IMPORT_STYLE=admin
NOMINATIM_THREADS=4
NOMINATIM_SHM_SIZE=1gb

# ------------------------------------------------------------
# 6. Storage
# ------------------------------------------------------------
# Storage provider: local, s3, or openlist.
NUXT_STORAGE_PROVIDER=s3

# Local storage provider.
NUXT_PROVIDER_LOCAL_PATH=/app/data/storage
NUXT_PROVIDER_LOCAL_BASE_URL=/storage

# S3-compatible storage provider. The default values match the MinIO sidecar.
NUXT_PROVIDER_S3_ENDPOINT=http://minio:9000
NUXT_PROVIDER_S3_BUCKET=lumamemo
NUXT_PROVIDER_S3_REGION=us-east-1
NUXT_PROVIDER_S3_ACCESS_KEY_ID=lumamemo
NUXT_PROVIDER_S3_SECRET_ACCESS_KEY=lumamemo-minio-password
NUXT_PROVIDER_S3_PREFIX=photos/
NUXT_PROVIDER_S3_CDN_URL=
NUXT_PROVIDER_S3_FORCE_PATH_STYLE=true

# OpenList storage provider.
NUXT_PROVIDER_OPENLIST_BASE_URL=
NUXT_PROVIDER_OPENLIST_ROOT_PATH=
NUXT_PROVIDER_OPENLIST_TOKEN=
NUXT_PROVIDER_OPENLIST_ENDPOINT_UPLOAD=/api/fs/put
NUXT_PROVIDER_OPENLIST_ENDPOINT_DOWNLOAD=
NUXT_PROVIDER_OPENLIST_ENDPOINT_LIST=
NUXT_PROVIDER_OPENLIST_ENDPOINT_DELETE=/api/fs/remove
NUXT_PROVIDER_OPENLIST_ENDPOINT_META=/api/fs/get
NUXT_PROVIDER_OPENLIST_PATH_FIELD=path
NUXT_PROVIDER_OPENLIST_CDN_URL=

# MinIO sidecar used when NUXT_STORAGE_PROVIDER=s3.
MINIO_IMAGE=minio/minio:latest
MINIO_MC_IMAGE=minio/mc:latest
MINIO_ROOT_USER=lumamemo
MINIO_ROOT_PASSWORD=lumamemo-minio-password
MINIO_BUCKET=lumamemo

# ------------------------------------------------------------
# 7. AI services
# ------------------------------------------------------------
# AI features are optional and can be enabled from the dashboard.
ML_LOCALAI_BASE_URL=http://lumamemo-localai:8080
ML_FACE_MODEL=

ML_VLM_PROVIDER=openai-compatible
ML_VLM_BASE_URL=
ML_VLM_API_KEY=
ML_VLM_MODEL=

ML_EMBEDDING_BASE_URL=https://api.jina.ai/v1
ML_EMBEDDING_API_KEY=
ML_EMBEDDING_MODEL=

ML_VECTOR_PROVIDER=qdrant
ML_VECTOR_BASE_URL=http://lumamemo-qdrant:6333
ML_VECTOR_API_KEY=
ML_VECTOR_COLLECTION_PREFIX=lumamemo

# Qdrant sidecar.
QDRANT_IMAGE=qdrant/qdrant:v1.18.2

# LocalAI sidecar for face extraction.
LOCALAI_IMAGE=localai/localai:v4.6.0-gpu-nvidia-cuda-12
LOCALAI_PORT=18080
LOCALAI_DEBUG=false
LOCALAI_DISABLE_HARDWARE_DEFAULTS=true
LOCALAI_MAX_ACTIVE_BACKENDS=1
LOCALAI_WATCHDOG_IDLE=true
LOCALAI_WATCHDOG_IDLE_TIMEOUT=15m
LOCALAI_WATCHDOG_BUSY=true
LOCALAI_WATCHDOG_BUSY_TIMEOUT=10m
HF_ENDPOINT=https://hf-mirror.com

# ------------------------------------------------------------
# 8. Upload validation
# ------------------------------------------------------------
NUXT_UPLOAD_MIME_WHITELIST_ENABLED=true
NUXT_UPLOAD_MIME_WHITELIST=image/jpeg,image/png,image/webp,image/gif,image/bmp,image/tiff,image/heic,image/heif,image/3fr,image/arw,image/cr2,image/cr3,image/crw,image/dcr,image/dng,image/erf,image/fff,image/iiq,image/kdc,image/mef,image/mos,image/mrw,image/nef,image/nrw,image/orf,image/pef,image/raf,image/rwl,image/rw2,image/srw,image/x3f,image/x-adobe-dng,image/x-canon-crw,image/x-canon-cr2,image/x-canon-cr3,image/x-epson-erf,image/x-fuji-raf,image/x-hasselblad-3fr,image/x-hasselblad-fff,image/x-kodak-dcr,image/x-kodak-kdc,image/x-leaf-iiq,image/x-leaf-mos,image/x-leica-rwl,image/x-mamiya-mef,image/x-minolta-mrw,image/x-nikon-nef,image/x-nikon-nrw,image/x-olympus-orf,image/x-panasonic-rw2,image/x-pentax-pef,image/x-samsung-srw,image/x-sigma-x3f,image/x-sony-arw,image/x-sony-sr2,image/x-sony-srf,video/quicktime,video/mp4
