# Admin user email (required)
CFRAME_ADMIN_EMAIL=
# Admin user name (default to Chronoframe, optional)
CFRAME_ADMIN_NAME=
# Admin user password (default to CF1234@!, optional)
CFRAME_ADMIN_PASSWORD=
CFRAME_IMAGE=chronoframe:latest
GATEWAY_IMAGE=nginx:alpine
GATEWAY_PORT=3000
CFRAME_DEBUG_PORT=3001

# Database provider (sqlite/postgres). SQLite is the lightweight default.
DATABASE_PROVIDER=sqlite
DATABASE_URL=/app/data/app.sqlite3

# PostgreSQL configuration used by docker compose when DATABASE_PROVIDER=postgres.
POSTGRES_DB=chronoframe
POSTGRES_USER=chronoframe
POSTGRES_PASSWORD=chronoframe-postgres-password
POSTGRES_PORT=5432
POSTGRES_IMAGE=postgres:18-alpine
# DATABASE_PROVIDER=postgres
# DATABASE_URL=postgres://chronoframe:chronoframe-postgres-password@postgres:5432/chronoframe

# Site configuration
# Color mode preference: light, dark, or system
NUXT_PUBLIC_COLOR_MODE_PREFERENCE=light

# Map Provider
NUXT_PUBLIC_MAP_PROVIDER=maplibre
# Local MapLibre style URL
NUXT_PUBLIC_MAP_MAPLIBRE_STYLE=/maps/style.json?v=global
# Optional Mapbox style URL
NUXT_PUBLIC_MAP_MAPBOX_STYLE=mapbox://styles/mapbox/standard
# Mapbox access token for map features, Mapbox GL JS (Client-side, public)
NUXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Mapbox secret access token for server-side, Mapbox Search API (Reverse Geocoding)
NUXT_MAPBOX_ACCESS_TOKEN=
PMTILES_IMAGE=protomaps/go-pmtiles:latest
PMTILES_TILESET=global
PMTILES_FILENAME=global.pmtiles
MAPLIBRE_IMAGE=nginx:alpine

# Custom Nominatim API base URL (use local Nominatim, MapBox, or a proxy when official API is blocked)
NUXT_NOMINATIM_BASE_URL=
NOMINATIM_IMAGE=mediagis/nominatim:5.3.2
NOMINATIM_PORT=8088
NOMINATIM_PBF_URL=https://download.geofabrik.de/asia/china-latest.osm.pbf
NOMINATIM_REPLICATION_URL=
NOMINATIM_PASSWORD=chronoframe-nominatim-password
NOMINATIM_IMPORT_STYLE=admin
NOMINATIM_THREADS=4
NOMINATIM_SHM_SIZE=1gb

# Storage provider (s3/local/openlist)
NUXT_STORAGE_PROVIDER=s3
MINIO_ROOT_USER=chronoframe
MINIO_ROOT_PASSWORD=chronoframe-minio-password
MINIO_BUCKET=chronoframe
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_IMAGE=minio/minio:latest
MINIO_MC_IMAGE=minio/mc:latest
# S3 storage provider configuration
NUXT_PROVIDER_S3_ENDPOINT=http://minio:9000
NUXT_PROVIDER_S3_BUCKET=chronoframe
NUXT_PROVIDER_S3_REGION=us-east-1
NUXT_PROVIDER_S3_ACCESS_KEY_ID=chronoframe
NUXT_PROVIDER_S3_SECRET_ACCESS_KEY=chronoframe-minio-password
NUXT_PROVIDER_S3_PREFIX=photos/
NUXT_PROVIDER_S3_CDN_URL=
NUXT_PROVIDER_S3_FORCE_PATH_STYLE=true

# Local storage provider configuration
NUXT_PROVIDER_LOCAL_PATH=./data/storage

# external access base URL for local storage, e.g. /storage (built-in /storage route)
NUXT_PROVIDER_LOCAL_BASE_URL=/storage

# OpenList storage provider configuration
# OpenList base URL, e.g. https://your-openlist-server.com.
NUXT_PROVIDER_OPENLIST_BASE_URL=
# OpenList root path, e.g. /115pan/chronoframe/photos
NUXT_PROVIDER_OPENLIST_ROOT_PATH=
# Authentication - Token authentication (recommended)
NUXT_PROVIDER_OPENLIST_TOKEN=
NUXT_PROVIDER_OPENLIST_ENDPOINT_UPLOAD=/api/fs/put
NUXT_PROVIDER_OPENLIST_ENDPOINT_DOWNLOAD=
NUXT_PROVIDER_OPENLIST_ENDPOINT_LIST=
NUXT_PROVIDER_OPENLIST_ENDPOINT_DELETE=/api/fs/remove
NUXT_PROVIDER_OPENLIST_ENDPOINT_META=/api/fs/get
NUXT_PROVIDER_OPENLIST_PATH_FIELD=path
NUXT_PROVIDER_OPENLIST_CDN_URL=

# Session password for encrypting session data, 32 characters long
NUXT_SESSION_PASSWORD=

# GitHub OAuth app credentials
NUXT_PUBLIC_OAUTH_GITHUB_ENABLED=false
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# DEPRECATED
# INSECURE Options - DO NOT use these options in production or on public networks
# Allow cookies to be transmitted over insecure connections, effects login session security
# NUXT_ALLOW_INSECURE_COOKIE=false

# Google Analytics Measurement ID (e.g. G-XXXXXXX)
NUXT_PUBLIC_GTAG_ID=
# Matomo Analytics configuration
NUXT_PUBLIC_ANALYTICS_MATOMO_ENABLED=false
NUXT_PUBLIC_ANALYTICS_MATOMO_URL=
NUXT_PUBLIC_ANALYTICS_MATOMO_SITE_ID=

# -----------------
# Upload Configuration
# -----------------
# Enable MIME type whitelist validation for file uploads (default: true)
NUXT_UPLOAD_MIME_WHITELIST_ENABLED=true

# Comma-separated list of allowed MIME types for uploads
# Default includes: image/jpeg, image/png, image/webp, image/gif, image/bmp,
#                   image/tiff, image/heic, image/heif, RAW camera MIME types,
#                   video/quicktime, video/mp4
NUXT_UPLOAD_MIME_WHITELIST=image/jpeg,image/png,image/webp,image/gif,image/bmp,image/tiff,image/heic,image/heif,image/3fr,image/arw,image/cr2,image/cr3,image/crw,image/dcr,image/dng,image/erf,image/fff,image/iiq,image/kdc,image/mef,image/mos,image/mrw,image/nef,image/nrw,image/orf,image/pef,image/raf,image/rwl,image/rw2,image/srw,image/x3f,image/x-adobe-dng,image/x-canon-crw,image/x-canon-cr2,image/x-canon-cr3,image/x-epson-erf,image/x-fuji-raf,image/x-hasselblad-3fr,image/x-hasselblad-fff,image/x-kodak-dcr,image/x-kodak-kdc,image/x-leaf-iiq,image/x-leaf-mos,image/x-leica-rwl,image/x-mamiya-mef,image/x-minolta-mrw,image/x-nikon-nef,image/x-nikon-nrw,image/x-olympus-orf,image/x-panasonic-rw2,image/x-pentax-pef,image/x-samsung-srw,image/x-sigma-x3f,image/x-sony-arw,image/x-sony-sr2,image/x-sony-srf,video/quicktime,video/mp4

# To disable whitelist and allow any file type, set:
# NUXT_UPLOAD_MIME_WHITELIST_ENABLED=false


# Duplicate file handling has been moved to System Settings page.
# Configure it in Dashboard -> Settings -> System:
# - Detect duplicate files on upload (enabled/disabled)
# - Duplicate file handling mode (skip/warn/block)
